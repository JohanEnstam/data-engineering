# Example environment file - Copy this to .env and fill in your API keys

# Trafiklab API Keys
TRAFIKLAB_API_KEY=your_gtfs_sweden_3_api_key_here
GTFS_SWEDEN_3_REALTIME_TRAFIKLAB_API_KEY=your_realtime_api_key_here
GTFS_SWEDEN_3_STATIC_DATA_TRAFIKLAB_API_KEY=your_static_api_key_here

# SMHI API (no key required, but can be used for rate limiting)
SMHI_API_KEY=

# Other API Keys (if needed later)
# RESROBOT_API_KEY=
# SL_API_KEY=

# Database Configuration (if needed later)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Note: Never commit your actual .env file to git!
# This file contains sensitive API keys and should be kept private.
